VITE_VAPID_PUBLIC_KEY=BA_eIZW9aB7UzzAFEApefa8cVmpUFBSJ9smosbaOJY3Lp7ZjpPWvl6oAp8H4WggZtu4e2zkebQJrvwcC5fyYOBg
