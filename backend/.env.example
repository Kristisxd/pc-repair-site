# Copy this file to .env and fill in real values. Never commit .env.

PORT=4000
FRONTEND_URL=http://localhost:5173

# Long random string, used to sign admin login sessions
JWT_SECRET=change-this-to-a-long-random-string

# Admin login (the one account: you, the shop owner)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=

# --- Reminder emails (appointments, 24h before) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="PC Fix <you@example.com>"

# --- Web Push (free phone notifications via browser/PWA) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Optional: SMS via Twilio instead of / in addition to push ---
# Guarantees delivery to any phone, costs ~$0.01-0.08 per text
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_PHONE_NUMBER=
